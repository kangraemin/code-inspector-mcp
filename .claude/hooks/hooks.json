{
  "PreToolUse": [
    {"matcher": "Write|Edit|MultiEdit", "file": "plan-gate.sh", "type": "managed"},
    {"matcher": "Bash", "file": "bash-gate.sh", "type": "managed"}
  ],
  "PostToolUse": [
    {"matcher": "Write|Edit|MultiEdit", "file": "doc-reminder.sh", "type": "managed"},
    {"matcher": "Bash", "file": "bash-audit.sh", "type": "managed"}
  ],
  "Stop": [
    {"file": "completion-gate.sh", "type": "managed"}
  ],
  "SubagentStart": [
    {"file": "subagent-track.sh", "type": "copy"}
  ],
  "SubagentStop": [
    {"file": "subagent-cleanup.sh", "type": "copy"}
  ]
}
